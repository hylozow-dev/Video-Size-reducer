# ==== Required ====
# Telegram bot token, obtained from @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# ==== Local Bot API server (required for files > 20MB download / > 50MB upload) ====
# Set to "true" only if you are running the bundled local Bot API server
# (see docker-compose.yml). Requires TELEGRAM_API_ID / TELEGRAM_API_HASH below.
USE_LOCAL_API=false

# Obtain these at https://my.telegram.org (API development tools)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Base URL of the local Bot API server (only used when USE_LOCAL_API=true)
LOCAL_API_BASE_URL=http://telegram-bot-api:8081

# ==== Storage ====
# Directory used for downloaded/processed video files.
# When using the local Bot API server in Docker, this MUST match the volume
# shared between the bot and the telegram-bot-api container.
STORAGE_DIR=/app/storage

# ==== Limits & behavior ====
# Maximum accepted input file size in MB. Telegram's local-server hard limit is 2000 MB.
MAX_INPUT_SIZE_MB=2000

# Maximum number of concurrent ffmpeg compression jobs across all users.
# HARD-CAPPED to 1 in code (bot/config.py) regardless of this value: the
# bot only ever processes one video at a time, to avoid overloading the
# host. Everyone else waits in an in-memory FIFO queue and is told an
# estimated wait time. This variable is kept for documentation purposes.
MAX_CONCURRENT_JOBS=1

# Default target size (MB) suggested to users when they don't pick a preset.
DEFAULT_TARGET_SIZE_MB=50

# ffmpeg/ffprobe binaries (override if not on PATH)
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# ==== Logging ====
LOG_LEVEL=INFO
